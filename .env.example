# ── Supabase (studio-media-cloud dedicated project) ──
NEXT_PUBLIC_SUPABASE_URL=https://lnclobwmfkxtibqnxgip.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY
# Server-only. Never expose to the browser. Dashboard → Project Settings → API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Public origin of the deployed app (used to build share URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Media store (S3-compatible: Cloudflare R2 or self-hosted MinIO) — added at M2 ──
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=studio-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public branded media host in front of the bucket, e.g. https://media.yourdomain
MEDIA_PUBLIC_BASE_URL=

# Optional: use your real logo image instead of the text wordmark.
# Add the file at public/brand/isaac.svg (or .png) and set this to its path.
NEXT_PUBLIC_LOGO_SRC=
